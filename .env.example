# IMAGIN.studio Environment Configuration
#
# Copy this file to .env and configure for your environment.
# Never commit .env files with actual credentials!

# =============================================================================
# GCP Configuration (optional)
# =============================================================================

# GCP Project ID (from project.yaml)
GCP_PROJECT_ID=

# Default GCP region for resources
GCP_REGION=europe-west4

# Service account for impersonation (configured via ADC)
# Local dev uses: gcloud auth application-default login --impersonate-service-account=SA
# GCP_SERVICE_ACCOUNT=sa-name@project.iam.gserviceaccount.com

# Feature flags
GCP_USE_GCLOUD_FALLBACK=true

# =============================================================================
# CLI Configuration
# =============================================================================

# Output format (table, json)
# CLI_OUTPUT_FORMAT=table

# Verbose logging
# CLI_VERBOSE=false

# =============================================================================
# img CLI - Atlassian Integration
# =============================================================================
# Get your OAuth client ID from: https://developer.atlassian.com/console/myapps/
# Create an OAuth 2.0 integration and add callback URL: http://localhost:37842/callback

# Atlassian OAuth Client ID (required for img login)
IMG_OAUTH_CLIENT_ID=your_oauth_client_id_here

# Atlassian domain (e.g., company.atlassian.net)
IMG_ATLASSIAN_DOMAIN=company.atlassian.net
